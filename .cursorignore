# Block from Cursor indexing and @-references (same syntax as .gitignore)

# Secrets (do not index)
.env
.env.local

# Pipeline and outputs (required for setup unit tests)
_targets/
analysis/output/
analysis/data/import/**
analysis/data/simulate/**

# R session / IDE
.Rhistory
.RData
.Rproj.user/

# OS
.DS_Store
